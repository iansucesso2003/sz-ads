# Supabase - Project Settings > Database
# DATABASE_URL: Connection string > URI (modo Transaction)
# DIRECT_URL: Connection string > URI (modo Session) - para migrations

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
AUTH_SECRET="cole-aqui-o-resultado-de-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"  # Em produção: https://seu-app.vercel.app

# OpenAI (para o chat com o agente)
OPENAI_API_KEY="sk-..."
